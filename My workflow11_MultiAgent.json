    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"isValid\":{\"type\":\"boolean\",\"description\":\"true nếu đây là giao dịch tài chính hợp lệ\"},\"isExpense\":{\"type\":\"boolean\",\"description\":\"true nếu là chi tiêu, false nếu là thu nhập\"},\"amount\":{\"type\":\"number\",\"description\":\"Số tiền, luôn dương\"},\"categoryName\":{\"type\":\"string\",\"enum\":[\"Food\",\"Transport\",\"Shopping\",\"Bills\",\"Salary\",\"Invest\",\"Rent\",\"Other\"],\"description\":\"Hạng mục giao dịch\"},\"note\":{\"type\":\"string\",\"description\":\"Tóm tắt nhanh bằng tiếng Việt\"},\"replyMessage\":{\"type\":\"string\",\"description\":\"Câu trả lời ngắn gọn cho người dùng\"}},\"required\":[\"isValid\",\"replyMessage\"]}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1400,
        250
      ],
      "id": "f4d3f188-1be3-4338-a360-28ad6ab43224",
