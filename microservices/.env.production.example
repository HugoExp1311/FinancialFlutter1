# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to git!

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Architecture Mode (use 'microservices' for production)
ARCHITECTURE_MODE=microservices

# Production API URL (for Flutter app to connect)
MICROSERVICE_URL=https://api-flutter.vault.io.vn

# N8N Webhook Configuration
N8N_WEBHOOK_URL=https://n8n.vault.io.vn/webhook/ai-chat

# Optional: Additional Configuration
# LOG_LEVEL=info
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# DATABASE_POOL_SIZE=10
